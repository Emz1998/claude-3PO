        "new_string": "def record_agent_start(agent_type: str, agent_id: str, state: StateStore) -> None:\n    \"\"\"Record an agent start with its unique agent_id.\"\"\"\n    state.add_agent(Agent(name=agent_type, status=\"in_progress\", tool_use_id=agent_id))",
