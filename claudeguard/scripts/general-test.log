            "content": "    def update_agent_status(\n        self, name: str, status: Literal[\"in_progress\", \"completed\"]\n    ) -> None:\n        def _update(d: dict) -> None:\n            agents = d.get(\"agents\", [])\n            agent = next(\n                (a for a in agents if a.get(\"name\") == name and a.get(\"status\") == \"in_progress\"),\n                None,\n            )\n            if agent:\n                agent[\"status\"] = status\n\n        self.update(_update)\n\n    # \u2500\u2500 Plan \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500",
