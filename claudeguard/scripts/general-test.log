{
    "session_id": "b43fc7cb-8eee-4919-9f96-14ea132e3e35",
    "transcript_path": "/home/emhar/.claude/projects/-home-emhar-avaris-ai/b43fc7cb-8eee-4919-9f96-14ea132e3e35.jsonl",
    "cwd": "/home/emhar/avaris-ai/scripts",
    "permission_mode": "default",
    "hook_event_name": "PostToolUse",
    "tool_name": "Edit",
    "tool_input": {
        "file_path": "/home/emhar/avaris-ai/scripts/utils/validators.py",
        "old_string": "hook_input.get(\"tool_input\", {}).get(\"agent_type\", \"\")",
        "new_string": "hook_input.get(\"tool_input\", {}).get(\"subagent_type\", \"\")",
