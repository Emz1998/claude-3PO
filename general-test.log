        "newString": "def record_plan(file_path: str, review: dict, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state.setdefault(\"plan\", {}).update(\n            {\n                \"file_path\": file_path,\n                \"written\": True,\n                \"review\": review,\n            }\n        )",
        "originalFile": "\"\"\"agents_recorder.py \u2014 State-mutation (recording) functions for workflow state.\n\nSimple record functions that update individual fields in the workflow state.\nEach function takes a value and a StateStore, and persists the change.\n\"\"\"\n\nimport sys\nfrom pathlib import Path\n\nsys.path.insert(0, str(Path(__file__).resolve().parent.parent))\n\nfrom scripts.state_store import StateStore\n\n\n# ---------------------------------------------------------------------------\n# Agent recording\n# ---------------------------------------------------------------------------\n\n\ndef record_agent_invocation(\n    store: StateStore, agent_type: str, tool_use_id: str\n) -> None:\n    \"\"\"Append an agent entry as 'running' to state.agents[].\"\"\"\n\n    def _update(state: dict) -> None:\n        state.setdefault(\"agents\", []).append(\n            {\n                \"agent_type\": agent_type,\n                \"status\": \"running\",\n                \"tool_use_id\": tool_use_id,\n            }\n        )\n\n    store.update(_update)\n\n\ndef record_agent_stoppage(store: StateStore, agent_type: str, tool_use_id: str) -> None:\n    \"\"\"Append an agent entry as 'completed' to state.agents[].\"\"\"\n\n    def _update(state: dict) -> None:\n        agents = state.get(\"agents\", [])\n        for agent in agents:\n            if (\n                agent.get(\"agent_type\") == agent_type\n                and agent.get(\"tool_use_id\") == tool_use_id\n            ):\n                agent[\"status\"] = \"completed\"\n                break\n        state[\"agents\"] = agents\n\n    store.update(_update)\n\n\n# ---------------------------------------------------------------------------\n# Write Recorders\n# ---------------------------------------------------------------------------\n\n\ndef record_plan(file_path: str, written: bool, review: dict, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state.setdefault(\"plan\", {}).update(\n            {\n                \"file_path\": file_path,\n                \"status\": \"written\",\n                \"review\": review,\n            }\n        )\n\n    store.update(_update)\n\n\ndef record_tests(\n    file_paths: list[str], review_result: dict, executed: bool, store: StateStore\n) -> None:\n    def _update(state: dict) -> None:\n        state.setdefault(\"tests\", {}).update(\n            {\n                \"file_paths\": file_paths,\n                \"review_result\": review_result,\n                \"executed\": executed,\n            }\n        )\n\n    store.update(_update)\n\n\ndef record_file_written(file_path: str, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        files = state.setdefault(\"files_written\", [])\n        if file_path not in files:\n            files.append(file_path)\n\n    store.update(_update)\n\n\ndef record_phase(phase: str, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"phase\"] = phase\n\n    store.update(_update)\n\n\ndef record_workflow_type(workflow_type: str, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"workflow_type\"] = workflow_type\n\n    store.update(_update)\n\n\ndef record_story_id(story_id: str, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"story_id\"] = story_id\n\n    store.update(_update)\n\n\ndef record_tdd(tdd: bool, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"tdd\"] = tdd\n\n    store.update(_update)\n\n\ndef record_skip(skip: list[str], store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"skip\"] = skip\n\n    store.update(_update)\n\n\ndef record_instructions(instructions: str, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"instructions\"] = instructions\n\n    store.update(_update)\n\n\ndef record_task(task: dict, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state.setdefault(\"tasks\", []).append(task)\n\n    store.update(_update)\n\n\ndef record_docs_to_read(docs: list[str], store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"docs_to_read\"] = docs\n\n    store.update(_update)\n\n\ndef record_validation_result(result: str, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"validation_result\"] = result\n\n    store.update(_update)\n\n\ndef record_pr_status(status: str, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"pr_status\"] = status\n\n    store.update(_update)\n\n\ndef record_ci_status(status: str, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"ci_status\"] = status\n\n    store.update(_update)\n\n\ndef record_report_written(written: bool, store: StateStore) -> None:\n    def _update(state: dict) -> None:\n        state[\"report_written\"] = written\n\n    store.update(_update)\n",
