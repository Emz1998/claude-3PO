{
    "session_id": "fd7e7ad8-b88c-4bb1-86c4-53195cdc3f55",
    "transcript_path": "/home/emhar/.claude/projects/-home-emhar-avaris-ai/fd7e7ad8-b88c-4bb1-86c4-53195cdc3f55.jsonl",
