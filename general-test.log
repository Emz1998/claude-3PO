 \"\"\"Append current state as a JSONL entry to history_path.\"\"\"\n        entry = json.dumps(self.load()) + \"\\n\"\n        with open(history_path, \"a\") as f:\n            f.write(entry)\n\n    @staticmethod\n    def latest_from_history(history_path: Path) -> dict[str, Any] | None:\n        \"\"\"Return the last archived entry or None.\"\"\"\n        history_fm = FileManager(history_path, lock=True)\n        entries = history_fm.load_file()\n        if not entries:\n            return None\n        return entries[-1] if isinstance(entries, list) else None\n\n    # \u2500\u2500 Phase \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n    @property\n    def phase(self) -> str:\n        return self.load().get(\"phase\", \"\")\n\n    @property\n    def sub_phase(self) -> str | None:\n        return self.load().get(\"sub_phase\")\n\n    @property\n    def completed_phases(self) -> list[str]:\n        return self.load().get(\"completed_phases\", [])\n\n    def set_phase(self, phase: str) -> None:\n        self.set(\"phase\", phase)\n\n    def set_sub_phase(self, sub_phase: str | None) -> None:\n        self.set(\"sub_phase\", sub_phase)\n\n    def complete_phase(self, phase: str) -> None:\n        def _complete(d: dict) -> None:\n            completed = d.get(\"completed_phases\", [])\n            if phase not in completed:\n                completed.append(phase)\n            d[\"completed_phases\"] = completed\n            d[\"sub_phase\"] = None\n\n        self.update(_complete)\n\n    def is_phase_completed(self, phase: str) -> bool:\n        return phase in self.completed_phases\n\n    # \u2500\u2500 Agents \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u250