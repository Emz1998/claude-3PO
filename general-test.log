        "originalFile": "CODE_EXTENSIONS = {\n    \".py\",\n    \".ts\",\n    \".tsx\",\n    \".js\",\n    \".jsx\",\n    \".go\",\n    \".rs\",\n    \".java\",\n    \".kt\",\n    \".swift\",\n    \".c\",\n    \".cpp\",\n    \".h\",\n    \".rb\",\n    \".sh\",\n}\n\n\nPR_COMMAND_PATTERNS = [r\"\\bgh\\s+pr\\s+create\\b\", r\"\\bgit\\s+push\\b\"]\nTEST_RUN_PATTERNS = [\n    r\"\\bpytest\\b\",\n    r\"\\bnpm\\s+test\\b\",\n    r\"\\byarn\\s+test\\b\",\n    r\"\\bgo\\s+test\\b\",\n    r\"\\bjest\\b\",\n    r\"\\bvitest\\b\",\n]\nCI_CHECK_PATTERNS = [r\"\\bgh\\s+pr\\s+checks\\b\", r\"\\bgh\\s+run\\s+view\\b\"]\n\n# ---------------------------------------------------------------------------\n# Skill / story ID patterns\n# ---------------------------------------------------------------------------\nSTORY_ID_PATTERN = r\"\\b([A-Z]{2,}-\\d+)\\b\"\n\n\n# ---------------------------------------------------------------------------\n# Valid PR commands\n# ---------------------------------------------------------------------------\n\n\nPR_COMMANDS = [\n    \"git push\",\n    \"git pull\",\n    \"git fetch\",\n    \"git merge\",\n    \"git rebase\",\n    \"git reset\",\n    \"git checkout\",\n    \"git switch\",\n    \"git commit\",\n]\n\n\nVALID_CI_CHECK_COMMANDS = [\n    \"gh run view\",\n    \"gh run review\",\n    \"gh run merge\",\n    \"gh run close\",\n    \"gh run list\",\n    \"gh run any-active\",\n]\n\nVALID_INSTALL_COMMANDS = [\n    \"npm install\",\n    \"yarn install\",\n    \"go get\",\n    \"pip install\",\n    \"gem install\",\n    \"brew install\",\n    \"apt-get install\",\n]\n\nREAD_ONLY_COMMANDS = [\n    \"ls\",\n    \"pwd\",\n    \"cat\",\n    \"head\",\n    \"tail\",\n    \"wc\",\n    \"file\",\n    \"which\",\n    \"whoami\",\n    \"printenv\",\n    \"date\",\n    \"uname\",\n    \"hostname\",\n    \"df\",\n    \"du\",\n    \"free\",\n    \"ps\",\n    \"git status\",\n    \"git log\",\n    \"git diff\",\n    \"git show\",\n    \"git blame\",\n    \"tree\",\n    \"grep\",\n    \"rg\",\n    \"ag\",\n    \"fd\",\n    \"stat\",\n    \"realpath\",\n    \"dirname\",\n    \"basename\",\n]\n\nCOMMANDS_MAP = {\n    \"install\": VALID_INSTALL_COMMANDS,\n    \"pr-create\": VALID_PR_COMMANDS,\n    \"ci-check\": VALID_CI_CHECK_COMMANDS,\n}\n\nTEST_FILE_PATTERNS = [\n    # JS / TS style\n    \"*.test.js\",\n    \"*.test.ts\",\n    \"*.test.jsx\",\n    \"*.test.tsx\",\n    # Python style\n    \"test_*.py\",\n    \"*_test.py\",\n    # Optional: JS test prefix style\n    \"test_*.js\",\n    \"test_*.ts\",\n    \"test_*.jsx\",\n    \"test_*.tsx\",\n]\n\n\nWRITE_COMMANDS = [\n    \"touch\",\n    \"mkdir\",\n    \"echo\",\n    \"cat\",\n    \"cp\",\n    \"mv\",\n    \"rm\",\n]\n",
