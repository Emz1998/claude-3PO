        "new_string": "def is_skill_allowed(\n    hook_input: dict, config: Config, state: StateStore\n) -> str:\n    \"\"\"Validate the skill. If the skill is not allowed, raise an error.\"\"\"\n    phase = state.phase\n    skill_name = hook_input.get(\"tool_input\", {}).get(\"skill\", \"\")\n\n    if phase == \"explore\" and skill_name == \"Research\":\n        return \"Running Research in parallel with Explore\"\n\n    if phase == \"explore\" and skill_name != \"Explore\":\n        raise ValueError(f\"Skill '{skill_name}' is not allowed in phase: {phase}\")\n\n    if phase == \"research\" and skill_name != \"Research\":\n        raise ValueError(f\"Skill '{skill_name}' is not allowed in phase: {phase}\")\n\n    return f\"{skill_name} skill is allowed in phase: {phase}\"",
