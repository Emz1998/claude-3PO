 @staticmethod\n    def get_phase(phases: list[dict[str, Any]], name: str) -> dict[str, Any]:\n        return next(p for p in phases if p.get(\"name\") == name)\n\n    def add_phase(self, phase: Phase) -> None:\n        def _add(d: dict) -> None:\n            existing = d.get(\"phases\", [])\n            if any(p.get(\"name\") == phase.name for p in existing):\n                return\n            d[\"phases\"] = [*existing, phase.model_dump()]\n\n        self.update(_add)\n\n    def add_tool(self, phase_name: str, tool: ToolUnion) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        tools = phase.get(\"tools\") or []\n        dump = tool.model_dump()\n        if dump not in tools:\n            tools.append(dump)\n        phase[\"tools\"] = tools\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def add_sub_phase(self, phase_name: str, sub_phase: SubPhase) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        subs = phase.get(\"sub_phases\") or []\n        if any(sp.get(\"name\") == sub_phase.name for sp in subs):\n            return\n        subs.append(sub_phase.model_dump())\n        phase[\"sub_phases\"] = subs\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def update_phase_status(\n        self, phase_name: str, status: Literal[\"in_progress\", \"completed\"]\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        phase[\"status\"] = status\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def update_sub_phase_status(\n        self,\n        phase_name: str,\n        sub_phase_name: str,\n        status: Literal[\"in_progress\", \"completed\"],\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        sub_phase = self.get_sub_phase(phase, sub_phase_name)\n        sub_phase[\"status\"] = status\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    @staticmethod\n    def get_sub_phase(phase: dict[str, Any], name: str) -> dict[str, Any]:\n        subs = phase.get(\"sub_phases\") or []\n        return next(sp for sp in subs if sp.get(\"name\") == name)\n\n    def add_agent(self, phase_name: str, agent: Agents) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        agents = phase.get(\"agents\") or []\n        agents.append(agent.model_dump())\n        phase[\"agents\"] = agents\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    @staticmethod\n    def get_agent(phase: dict[str, Any], name: str) -> dict[str, Any]:\n        agents = phase.get(\"agents\") or []\n        return next(a for a in agents if a.get(\"name\") == name)\n\n    def update_agent_status(\n        self,\n        phase_name: str,\n        agent_name: str,\n        status: Literal[\"in_progress\", \"completed\"],\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        agent = self.get_agent(phase, agent_name)\n        agent[\"status\"] = status\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def add_sub_phase_agent(\n        self, phase_name: str, sub_phase_name: str, agent: Agents\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        sub_phase = self.get_sub_phase(phase, sub_phase_name)\n        agents = sub_phase.get(\"agents\") or []\n        agents.append(agent.model_dump())\n        sub_phase[\"agents\"] = agents\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def add_sub_phase_tool(\n        self, phase_name: str, sub_phase_name: str, tool: ToolUnion\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        sub_phase = self.get_sub_phase(phase, sub_phase_name)\n        tools = sub_phase.get(\"tools\") or []\n        dump = tool.model_