            "content": "\ndef required_agents_invoked(phase_name: str, config: Config, state: StateStore) -> str:\n    \"\"\"Check a phase has the required agents recorded in state.\"\"\"\n    expected_agents = config.get_required_agents(phase_name)\n    if not expected_agents:\n        return f\"No agents required for phase '{phase_name}'\"\n\n    try:\n        phase_state = state.get_phase(state.phases, phase_name)\n    except StopIteration:\n        raise ValueError(f\"Phase '{phase_name}' not found in state\")\n\n    for agent_name in expected_agents:\n        actual = state.count_agents(phase_state, agent_name)\n        if actual < 1:\n            raise ValueError(\n                f\"Phase '{phase_name}' requires agent '{agent_name}', found {actual}\"\n            )\n        max_allowed = config.get_agent_max_count(agent_name)\n        if actual > max_allowed:\n            raise ValueError(\n                f\"Phase '{phase_name}' allows max {max_allowed} '{agent_name}' agent(s), found {actual}\"\n            )\n\n    return f\"All required agents invoked for phase '{phase_name}'\"\n",
