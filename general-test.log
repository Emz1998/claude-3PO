 Explore,\n    Research,\n    QualityAssurance,\n    TestReviewer,\n    CodeReviewer,\n    PlanReview,\n    Plan,\n]\n\nREQUIRED_AGENTS = {\n    explore= (Explore, Research),\n    plan= (Plan,),\n    plan-review= (PlanReview,),\n    write-tests= (TestReviewer,),\n    validate= (QualityAssurance,),\n    code-review= (CodeReviewer,),\n    write-report= (Report,),\n}\n\n[required_agents]\nexplore = [Explore, Research]\nplan = [Plan]\nplan-review= (PlanReview,),\nwrite-tests= (TestReviewer,),\nvalidate= (QualityAssurance,),\ncode-review= (CodeReviewer,),\nwrite-report= (Report,),\n\n[score_thresholds.plan]\nconfidence_score = 90\nquality = 90\n\n[score_thresholds.tests]\nconfidence_score = 90\nquality = 90\n\n[score_thresholds.code]\nconfidence_score = 90\nquality = 90\n\n\n\n\nVALID_AGENTS = get_args(AgentType)\n\nWRITE_COMMANDS = [\ntouch,\nmkdir,\necho,\ncat,\ncp,\nmv,\nrm,\n]\n"
