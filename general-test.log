{
    "session_id": "8a0abc5b-2e38-4f37-9fd0-e9b987b8011e",
    "transcript_path": "/home/emhar/.claude/projects/-home-emhar-avaris-ai/8a0abc5b-2e38-4f37-9fd0-e9b987b8011e.jsonl",
    "cwd": "/home/emhar/avaris-ai",
