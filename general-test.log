        "originalFile": "import json\nfrom pathlib import Path\n\n_CONFIG_PATH = Path(__file__).parent / \"config.json\"\n\nwith open(_CONFIG_PATH) as f:\n    _CONFIG = json.load(f)\n\nPHASE_REQUIREMENTS: list[dict] = _CONFIG[\"phases\"]\n\n\ndef get_phase_requirement(phase: str) -> dict | None:\n    return next((p for p in PHASE_REQUIREMENTS if p[\"name\"] == phase), None)\n\n\ndef get_sub_phases(phase: str) -> list[dict]:\n    req = get_phase_requirement(phase)\n    return req.get(\"sub_phases\") or [] if req else []\n\n\ndef get_sub_phase(phase: str, name: str) -> dict | None:\n    return next((sp for sp in get_sub_phases(phase) if sp[\"name\"] == name), None)\n\n\ndef get_phase_agents(phase: str) -> list[dict]:\n    req = get_phase_requirement(phase)\n    return req.get(\"agents\") or [] if req else []\n\n\ndef get_phase_tools(phase: str) -> list[dict]:\n    req = get_phase_requirement(phase)\n    return req.get(\"tools\") or [] if req else []\n\n\ndef get_phase_tool(phase: str, tool_name: str) -> dict | None:\n    return next((t for t in get_phase_tools(phase) if t[\"name\"] == tool_name), None)\n\n\ndef get_phases_with_sub_phases() -> list[str]:\n    return [p[\"name\"] for p in PHASE_REQUIREMENTS if p.get(\"sub_phases\")]\n\n\ndef get_all_phase_names() -> list[str]:\n    return [p[\"name\"] for p in PHASE_REQUIREMENTS]\n\n\nTOOLS_SCHEMA = {\n    \"name\": str,\n    \"file_paths\": list[str],\n    \"turns\": int,\n    \"commands\": list[str],\n}\n"
