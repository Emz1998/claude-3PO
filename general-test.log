    "permission_mode": "bypassPermissions",
    "hook_event_name": "PostToolUse",
    "tool_name": "Edit",
    "tool_input": {
        "file_path": "/home/emhar/avaris-ai/scripts/utils/validators.py",
        "old_string": "    docs_only_phases = config.docs_phases",
        "new_string": "    docs_only_phases = config.docs_write_phases",
