{
    "session_id": "b43fc7cb-8eee-4919-9f96-14ea132e3e35",
    "transcript_path": "/home/emhar/.claude/projects/-home-emhar-avaris-ai/b43fc7cb-8eee-4919-9f96-14ea132e3e35.jsonl",
