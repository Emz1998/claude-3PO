        "originalFile": "\"\"\"StateStore \u2014 JSON state with file-locking.\"\"\"\n\nimport json\nfrom pathlib import Path\nfrom typing import Any, Callable, Literal\nimport sys\n\n\nfrom ..models.state import Phase, SubPhase, Agents, ToolUnion, ReadTool\nfrom .file_manager import FileManager\n\n\nclass StateStore:\n    def __init__(self, state_path: Path, default_state: dict[str, Any] | None = None):\n        self._path = state_path\n        self._default_state = default_state or {}\n        self._fm = FileManager(self._path, lock=True)\n\n    def load(self) -> dict[str, Any]:\n        if not self._path.exists():\n            return dict(self._default_state)\n        return self._fm.load_file()\n\n    def save(self, state: dict[str, Any] | None = None) -> None:\n        self._fm.save_file(state)\n\n    def update(self, fn: Callable[[dict[str, Any]], None]) -> None:\n        def _seeded(data: dict) -> None:\n            if not data and self._default_state:\n                data.update(self._default_state)\n            fn(data)\n\n        self._fm.update_file(_seeded)\n\n    def get(self, key: str, default: Any = None) -> Any:\n        data = self.load()\n        return data.get(key, default)\n\n    def set(self, key: str, value: Any) -> None:\n        self.update(lambda d: d.update({key: value}))\n\n    def reset(self, default_state: dict[str, Any] | None = None) -> None:\n        self._fm.save_file(default_state or {})\n\n    def reinitialize(self, initial_state: dict[str, Any]) -> None:\n        self._fm.save_file(initial_state)\n\n    def delete(self) -> None:\n        self._path.unlink(missing_ok=True)\n\n    def archive(self, history_path: Path) -> None:\n        \"\"\"Append current state as a JSONL entry to history_path.\"\"\"\n        entry = json.dumps(self.load()) + \"\\n\"\n        with open(history_path, \"a\") as f:\n            f.write(entry)\n\n    @property\n    def phases(self) -> list[dict]:\n        return self.load().get(\"phases\", [])\n\n    def get_phase(self, phases: list[dict[str, Any]], name: str) -> dict[str, Any]:\n        return next(p for p in phases if p.get(\"name\") == name)\n\n    def add_phase(self, phase: Phase) -> None:\n        def _add(d: dict) -> None:\n            existing = d.get(\"phases\", [])\n            if any(p.get(\"name\") == phase.name for p in existing):\n                return\n            d[\"phases\"] = [*existing, phase.model_dump()]\n\n        self.update(_add)\n\n    def add_tool(self, phase_name: str, tool: ToolUnion) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        tools = phase.get(\"tools\") or []\n        dump = tool.model_dump()\n        if dump not in tools:\n            tools.append(dump)\n        phase[\"tools\"] = tools\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def add_sub_phase(self, phase_name: str, sub_phase: SubPhase) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        subs = phase.get(\"sub_phases\") or []\n        if any(sp.get(\"name\") == sub_phase.name for sp in subs):\n            return\n        subs.append(sub_phase.model_dump())\n        phase[\"sub_phases\"] = subs\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def update_phase_status(\n        self, phase_name: str, status: Literal[\"in_progress\", \"completed\"]\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        phase[\"status\"] = status\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def update_sub_phase_status(\n        self,\n        phase_name: str,\n        sub_phase_name: str,\n        status: Literal[\"in_progress\", \"completed\"],\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        sub_phase = self.get_sub_phase(phase, sub_phase_name)\n        sub_phase[\"status\"] = status\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def get_sub_phase(self, phase: dict[str, Any], name: str) -> dict[str, Any]:\n        subs = phase.get(\"sub_phases\") or []\n        return next(sp for sp in subs if sp.get(\"name\") == name)\n\n    def get_phase_agents(self, phase: dict[str, Any]) -> list[dict]:\n        return phase.get(\"agents\") or []\n\n    def get_phase_tools(self, phase: dict[str, Any]) -> list[dict]:\n        return phase.get(\"tools\") or []\n\n    def get_sub_phase_agents(self, sub_phase: dict[str, Any]) -> list[dict]:\n        return sub_phase.get(\"agents\") or []\n\n    def get_sub_phase_tools(self, sub_phase: dict[str, Any]) -> list[dict]:\n        return sub_phase.get(\"tools\") or []\n\n    def count_agents(self, phase: dict[str, Any], agent_name: str) -> int:\n        return sum(1 for a in self.get_phase_agents(phase) if a.get(\"name\") == agent_name)\n\n    def count_sub_phase_agents(self, sub_phase: dict[str, Any], agent_name: str) -> int:\n        return sum(1 for a in self.get_sub_phase_agents(sub_phase) if a.get(\"name\") == agent_name)\n\n    def add_agent(self, phase_name: str, agent: Agents) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        agents = phase.get(\"agents\") or []\n        agents.append(agent.model_dump())\n        phase[\"agents\"] = agents\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def get_agent(self, phase: dict[str, Any], name: str) -> dict[str, Any]:\n        agents = phase.get(\"agents\") or []\n        return next(a for a in agents if a.get(\"name\") == name)\n\n    def update_agent_status(\n        self,\n        phase_name: str,\n        agent_name: str,\n        status: Literal[\"in_progress\", \"completed\"],\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        agent = self.get_agent(phase, agent_name)\n        agent[\"status\"] = status\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def add_sub_phase_agent(\n        self, phase_name: str, sub_phase_name: str, agent: Agents\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        sub_phase = self.get_sub_phase(phase, sub_phase_name)\n        agents = sub_phase.get(\"agents\") or []\n        agents.append(agent.model_dump())\n        sub_phase[\"agents\"] = agents\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def add_sub_phase_tool(\n        self, phase_name: str, sub_phase_name: str, tool: ToolUnion\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        sub_phase = self.get_sub_phase(phase, sub_phase_name)\n        tools = sub_phase.get(\"tools\") or []\n        dump = tool.model_dump()\n        if dump not in tools:\n            tools.append(dump)\n        sub_phase[\"tools\"] = tools\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    def update_sub_phase_agent_status(\n        self,\n        phase_name: str,\n        sub_phase_name: str,\n        agent_name: str,\n        status: Literal[\"in_progress\", \"completed\"],\n    ) -> None:\n        phases = self.phases\n        phase = self.get_phase(phases, phase_name)\n        sub_phase = self.get_sub_phase(phase, sub_phase_name)\n        agent = self.get_agent(sub_phase, agent_name)\n        agent[\"status\"] = status\n        self.update(lambda d: d.update({\"phases\": phases}))\n\n    @staticmethod\n    def latest_from_history(history_path: Path) -> dict[str, Any] | None:\n        \"\"\"Return the last archived entry or None.\"\"\"\n        history_fm = FileManager(history_path, lock=True)\n        entries = history_fm.load_file()\n        if not entries:\n            return None\n        return entries[-1] if isinstance(entries, list) else None\n\n\nif __name__ == \"__main__\":\n    state_store = StateStore(Path(__file__).resolve().parent.parent / \"state.json\")\n    tool = ReadTool(name=\"Read\", file_paths=[\"README.md\"], turns=1)\n    state_store.add_phase(Phase(name=\"explore\", status=\"in_progress\"))\n"
    },
    "tool_use_id": "toolu_01L4nq4YeSptbLKhiY2Vy343"
}
