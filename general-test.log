        "file": {
            "filePath": "/home/emhar/avaris-ai/scripts/config.py",
            "content": "import json\nfrom pathlib import Path\nfrom typing import Any\n\n\nclass Config:\n    def __init__(self, config_path: Path | None = None):\n        self._path = config_path or Path(__file__).parent / \"config.json\"\n        with open(self._path) as f:\n            self._data: dict[str, Any] = json.load(f)\n        self.phases: list[dict] = self._data[\"phases\"]\n\n    def get_phase(self, name: str) -> dict | None:\n        return next((p for p in self.phases if p[\"name\"] == name), None)\n\n    def get_sub_phases(self, phase: str) -> list[dict]:\n        req = self.get_phase(phase)\n        return req.get(\"sub_phases\") or [] if req else []\n\n    def get_sub_phase(self, phase: str, name: str) -> dict | None:\n        return next((sp for sp in self.get_sub_phases(phase) if sp[\"name\"] == name), None)\n\n    def get_phase_agents(self, phase: str) -> list[dict]:\n        req = self.get_phase(phase)\n        return req.get(\"agents\") or [] if req else []\n\n    def get_phase_tools(self, phase: str) -> list[dict]:\n        req = self.get_phase(phase)\n        return req.get(\"tools\") or [] if req else []\n\n    def get_phase_tool(self, phase: str, tool_name: str) -> dict | None:\n        return next((t for t in self.get_phase_tools(phase) if t[\"name\"] == tool_name), None)\n\n    def get_phases_with_sub_phases(self) -> list[str]:\n        return [p[\"name\"] for p in self.phases if p.get(\"sub_phases\")]\n\n    def get_all_phase_names(self) -> list[str]:\n        return [p[\"name\"] for p in self.phases]\n\n    def get_sub_phase_agents(self, phase: str, sub_phase: str) -> list[dict]:\n        sp = self.get_sub_phase(phase, sub_phase)\n        return sp.get(\"agents\") or [] if sp else []\n\n    def get_sub_phase_tools(self, phase: str, sub_phase: str) -> list[dict]:\n        sp = self.get_sub_phase(phase, sub_phase)\n        return sp.get(\"tools\") or [] if sp else []\n\n    def get_sub_phase_tool(self, phase: str, sub_phase: str, tool_name: str) -> dict | None:\n        return next(\n            (t for t in self.get_sub_phase_tools(phase, sub_phase) if t[\"name\"] == tool_name),\n            None,\n        )\n\n    def get_required_agent_count(self, phase: str, agent_name: str) -> int:\n        agents = self.get_phase_agents(phase)\n        agent = next((a for a in agents if a[\"name\"] == agent_name), None)\n        return agent.get(\"count\", 1) if agent else 0\n\n    def get_required_sub_phase_agent_count(\n        self, phase: str, sub_phase: str, agent_name: str\n    ) -> int:\n        agents = self.get_sub_phase_agents(phase, sub_phase)\n        agent = next((a for a in agents if a[\"name\"] == agent_name), None)\n        return agent.get(\"count\", 1) if agent else 0\n",
