        "old_string": "def validate(state: StateStore, hook_input: dict, config: Config) -> str:\n    \"\"\"Validate the phase(skill). If the phase is not allowed, raise an error. Note: Phase is equivalent to hook skill\"\"\"\n\n    validators = [\n        is_phase_allowed,\n        is_file_write_allowed,\n        is_file_edit_allowed,\n        is_agent_allowed,\n        is_pr_commands_allowed,\n    ]\n    for validator in validators:\n        if validator(state, hook_input):\n            return validator(state, hook_input)\n    return \"All validators passed\"",
