        "originalFile": "# ---------------------------------------------------------------------------\n# Phase classifications\n# ---------------------------------------------------------------------------\nMAIN_PHASES = [\"explore\", \"research\", \"plan\", \"plan-review\", \"write-tests\", \"test-review\",\"write-code\", \"quality-check\", \"code-review\", \"pr-create\", \"ci-check\", \"write-report\"]\nSUBPHASES = [\"plan-revision\", \"refactor\"]\n\nREAD_ONLY_PHASES = [\"explore\",\"plan\", \"research\", \"plan-review\", \"test-review\", \"code-review\", \"quality-check\", \"report\"]\nCODE_WRITE_PHASES = [\"write-tests\", \"write-code\", \"refactor\"]\nCODE_EDIT_PHASES = [\"refactor\", \"plan-revision\"]\nDOCS_WRITE_PHASES = [\"plan\", \"report\"]\nDOCS_EDIT_PHASES = [\"plan-review\"]\nCHECKPOINT_PHASE = [\"present-plan\"]\n\n# ---------------------------------------------------------------------------\n# Agent invocation limits\n# ---------------------------------------------------------------------------\nEXPLORE_MAX = 3\nRESEARCH_MAX = 2\nPLAN_MAX = 1\nPLAN_REVIEW_MAX = 3\nTEST_REVIEWER_MAX = 3\nQA_SPECIALIST_MAX = 1\nCODE_REVIEWER_MAX = 3\n\n\n# ---------------------------------------------------------------------------\n# Safe domains for web access\n# ---------------------------------------------------------------------------\nSAFE_DOMAINS = [\n    \"docs.python.org\",\n    \"docs.anthropic.com\",\n    \"developer.mozilla.org\",\n    \"reactjs.org\",\n    \"react.dev\",\n    \"nextjs.org\",\n    \"tailwindcss.com\",\n    \"github.com\",\n    \"stackoverflow.com\",\n    \"pypi.org\",\n    \"npmjs.com\",\n    \"typescriptlang.org\",\n    \"nodejs.org\",\n    \"firebase.google.com\",\n    \"supabase.com\",\n    \"expo.dev\",\n    \"reactnative.dev\",\n    \"code.claude.com\",\n    \"vercel.com\",\n    \"medium.com\",\n    \"web.dev\",\n    \"developers.google.com\",\n    \"css-tricks.com\",\n]\n\n\n# ---------------------------------------------------------------------------\n# Required agents per phase (empty string = no agent required)\n# ---------------------------------------------------------------------------\n[REQUIRED_AGENTS]\nexplore = \"Explore\"\nresearch = \"Research\"\nplan = \"\"\nplan-review = \"PlanReview\"\nwrite-tests = \"\"\ntest-review = \"TestReviewer\"\nwrite-code = \"\"\nquality-check = \"QASpecialist\"\ncode-review = \"CodeReviewer\"\npr-create = \"\"\nci-check = \"\"\nwrite-report = \"\"\n\n\n# ---------------------------------------------------------------------------\n# Mapped Subphases: a review phase to its follow-up sub-phase\n# ---------------------------------------------------------------------------\n[REQUIRED_SUBPHASES]\nplan-review = \"plan-revision\"\ntest-review = \"refactor\"\ncode-review = \"refactor\"\n\n\n# ---------------------------------------------------------------------------\n# Score thresholds\n# ---------------------------------------------------------------------------\n[SCORE_THRESHOLDS.plan]\nconfidence_score = 90\nquality = 90\n\n[SCORE_THRESHOLDS.tests]\nconfidence_score = 90\nquality = 90\n\n[SCORE_THRESHOLDS.code]\nconfidence_score = 90\nquality = 90\n\n# ---------------------------------------------------------------------------\n# File Paths\n# ---------------------------------------------------------------------------\n[FILE_PATHS]\nDEFAULT_STATE_JSONL = \".claude/state.jsonl\"\nLOG_FILE = \"build.log\"\nDEBUG_LOG_FILE = \"debug.log\"\nPLAN_FILE_PATH = \".claude/plans/plan.md\"\nTEST_FILE_PATH = \".claude/tests/test.md\"\nCODE_FILE_PATH = \".claude/code/code.md\"\nREPORT_FILE_PATH = \".claude/reports/report.md\"\n",
