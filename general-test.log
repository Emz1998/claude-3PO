            "content": "    # \u2500\u2500 Phase \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n    @property\n    def phase(self) -> str:\n        return self.load().get(\"phase\", \"\")\n\n    @property\n    def sub_phase(self) -> str | None:\n        return self.load().get(\"sub_phase\")\n\n    @property\n    def completed_phases(self) -> list[str]:\n        return self.load().get(\"completed_phases\", [])\n\n    def set_phase(self, phase: str) -> None:\n        self.set(\"phase\", phase)\n\n    def set_sub_phase(self, sub_phase: str | None) -> None:\n        self.set(\"sub_phase\", sub_phase)\n\n    def complete_phase(self, phase: str) -> None:\n        def _complete(d: dict) -> None:\n            completed = d.get(\"completed_phases\", [])\n            if phase not in completed:\n                completed.append(phase)\n            d[\"completed_phases\"] = completed\n            d[\"sub_phase\"] = None\n\n        self.update(_complete)\n\n    def is_phase_completed(self, phase: str) -> bool:\n        return phase in self.completed_phases\n\n    # \u2500\u2500 Agents \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
