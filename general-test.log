            "content": "from pydantic import BaseModel, Field\nfrom typing import Literal\n\n\nclass Agent(BaseModel):\n    name: str\n    status: str | None = None\n    tool_use_id: str | None = None\n\n\nclass Tool(BaseModel):\n    name: Literal[\"Read\", \"Write\", \"Glob\", \"Grep\", \"Bash\", \"WebSearch\", \"WebFetch\"]\n    turns: int\n\n\nclass _FileTool(Tool):\n    file_paths: list[str]\n\n\nclass ReadTool(_FileTool):\n    name: Literal[\"Read\"] = \"Read\"\n\n\nclass WriteTool(_FileTool):\n    name: Literal[\"Write\"] = \"Write\"\n\n\nclass GlobTool(_FileTool):\n    name: Literal[\"Glob\"] = \"Glob\"\n\n\nclass GrepTool(_FileTool):\n    name: Literal[\"Grep\"] = \"Grep\"\n\n\nclass BashTool(Tool):\n    name: Literal[\"Bash\"] = \"Bash\"\n    commands: list[str]\n\n\nclass WebFetchTool(Tool):\n    name: Literal[\"WebFetch\"] = \"WebFetch\"\n    urls: list[str]\n\n\nclass WebSearchTool(Tool):\n    name: Literal[\"WebSearch\"] = \"WebSearch\"\n\n\nclass Phase(BaseModel):\n    name: str\n    sub_phases: list[str] | None = None\n    agents: list[str] | None = None\n    tools: list[str] | None = None\n\n\nclass State(BaseModel):\n    session_id: str\n    workflow_active: bool\n    workflow_type: str\n    tdd: bool\n    story_id: str\n",
