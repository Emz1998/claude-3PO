        "oldString": "def is_explore_completed(state: StateStore) -> bool:",
        "newString": "def is_explore_completed(config: Config, state: StateStore) -> str:\n    \"\"\"Check all Explore agents have completed.\"\"\"\n    agent_name = config.get_required_agent(\"explore\")\n    if not agent_name:\n        return \"No agent required for explore phase\"\n\n    agents = [a for a in state.agents if a.get(\"name\") == agent_name]\n    if not agents:\n        raise ValueError(f\"No '{agent_name}' agents found in state\")\n\n    pending = [a for a in agents if a.get(\"status\") != \"completed\"]\n    if pending:\n        raise ValueError(\n            f\"Explore not complete: {len(pending)} '{agent_name}' agent(s) still in progress\"\n        )\n\n    return f\"Explore completed: all {len(agents)} '{agent_name}' agent(s) done\"",
        "originalFile": "\"\"\"recorder.py \u2014 All state-mutation (recording) logic for workflow hooks.\n\nGuards handle validation (allow/block). This module handles recording:\ntracking agents, files, phases, scores, and other state changes that\nhappen after a tool use is allowed.\n\nUsage:\n    python3 recorder.py --hook-input '{\"hook_event_name\":\"PostToolUse\",...}'\n\nEnvironment:\n    RECORDER_STATE_PATH \u2014 override the default state.json path\n\"\"\"\n\nfrom pathlib import Path\nfrom typing import Literal, get_args, Any, TypeVar, Generic\nimport sys\nimport tomllib\n\n\nfrom .. import (\n    VALID_PR_COMMANDS,\n    TEST_FILE_PATTERNS,\n    CODE_EXTENSIONS,\n)\n\nfrom ..models.state import *\nfrom .state_store import StateStore\nfrom .helpers import validate_order\nfrom ..config import Config\n\n\ndef load_config() -> dict[str, Any]:\n    with open(\"config.toml\", \"rb\") as f:\n        config = tomllib.load(f)\n\n    return config\n\n\ndef is_pr_commands_allowed(\n    state: dict[str, Any], hook_input: dict, config: dict[str, Any]\n) -> str:\n\n    phase = state.get(\"phase\", \"\")\n    \"\"\"Validate the PR command.\"\"\"\n\n    tool_name = hook_input.get(\"tool_name\", \"\")\n\n    if tool_name != \"Bash\":\n        raise ValueError(f\"Invalid tool name: {tool_name}\")\n\n    if phase != \"pr-create\":\n        return \"Skipping, not in PR create phase\"\n\n    command = hook_input.get(\"tool_input\", {}).get(\"command\", \"\")\n\n    valid_pr_commands = config.get(\"VALID_PR_COMMANDS\", [])\n    if command not in valid_pr_commands:\n        raise ValueError(f\"Invalid PR command: {command}\")\n\n    return f\"PR command {command} is allowed in phase: {phase}\"\n\n\ndef is_file_write_allowed(hook_input: dict, config: Config, state: StateStore) -> str:\n    \"\"\"Validate the code files. If extensions are not supported, raise an error.\"\"\"\n    phase = state.phase\n    tool_name = hook_input.get(\"tool_name\", \"\")\n    tool_input = hook_input.get(\"tool_input\", {})\n\n    if tool_name != \"Write\":\n        return \"Skipping, not a Write tool\"\n\n    file_path = tool_input.get(\"file_path\", \"\")\n\n    if phase not in (\"plan\", \"write-tests\", \"write-code\", \"write-report\"):\n        raise ValueError(f\"File write not allowed in phase: {phase}\")\n\n    if phase == \"plan\":\n        if file_path != config.plan_file_path:\n            raise ValueError(\n                f\"Writing in '{file_path}' is not allowed in phase: {phase}\"\n                f\"\\nAllowed path: {config.plan_file_path}\"\n            )\n\n    if phase == \"write-tests\":\n        if not any(\n            file_path.match(test_pattern) for test_pattern in TEST_FILE_PATTERNS\n        ):\n            raise ValueError(\n                f\"Writing test file in '{file_path}' is not allowed in phase: {phase}\"\n                f\"\\nAllowed patterns: {TEST_FILE_PATTERNS}\"\n            )\n\n    if phase == \"write-code\":\n        if not any(file_path.endswith(ext) for ext in CODE_EXTENSIONS):\n            raise ValueError(\n                f\"Writing code file in '{file_path}' is not allowed in phase: {phase}\"\n                f\"\\nAllowed extensions: {CODE_EXTENSIONS}\"\n            )\n\n    if phase == \"write-report\":\n        if file_path != config.report_file_path:\n            raise ValueError(\n                f\"Writing report file in '{file_path}' is not allowed in phase: {phase}\"\n                f\"\\nAllowed path: {config.report_file_path}\"\n            )\n\n    record_file_write(phase, file_path, state)\n\n    return f\"File write allowed in phase: {phase}\"\n\n\ndef record_file_write(phase: str, file_path: str, state: StateStore) -> None:\n    if phase == \"plan\":\n        state.set_plan_file_path(file_path)\n        state.set_plan_written(True)\n    elif phase == \"write-tests\":\n        state.add_test_file(file_path)\n    elif phase == \"write-code\":\n        state.add_code_file(file_path)\n    elif phase == \"write-report\":\n        state.set_report_written(True)\n\n\ndef is_file_edit_allowed(\n    hook_input: dict, config: Config, state: StateStore\n) -> str:\n    \"\"\"Validate the code files. If extensions are not supported, raise an error.\"\"\"\n    phase = state.phase\n    tool_name = hook_input.get(\"tool_name\", \"\")\n    tool_input = hook_input.get(\"tool_input\", {})\n\n    if tool_name != \"Edit\":\n        return \"Skipping, not an Edit tool\"\n\n    file_path = tool_input.get(\"file_path\", \"\")\n\n    if phase not in (\"plan-review\", \"test-review\", \"code-review\"):\n        raise ValueError(f\"File edit not allowed in phase: {phase}\")\n\n    if phase == \"plan-review\":\n        if file_path != config.plan_file_path:\n            raise ValueError(\n                f\"Editing '{file_path}' is not allowed in phase: {phase}\"\n                f\"\\nAllowed path: {config.plan_file_path}\"\n            )\n\n    if phase == \"test-review\":\n        if file_path != config.test_file_path:\n            raise ValueError(\n                f\"Editing '{file_path}' is not allowed in phase: {phase}\"\n                f\"\\nAllowed path: {config.test_file_path}\"\n            )\n\n    if phase == \"code-review\":\n        if file_path != config.code_file_path:\n            raise ValueError(\n                f\"Editing '{file_path}' is not allowed in phase: {phase}\"\n                f\"\\nAllowed path: {config.code_file_path}\"\n            )\n\n    return f\"File edit allowed in phase: {phase}\"\n\n\ndef is_agent_allowed(\n    hook_input: dict, config: Config, state: StateStore\n) -> str:\n    \"\"\"Validate the agent. If the agent is not allowed, raise an error.\"\"\"\n    phase = state.phase\n    tool_name = hook_input.get(\"tool_name\", \"\")\n    tool_input = hook_input.get(\"tool_input\", {})\n\n    if tool_name != \"Agent\":\n        return \"Skipping, not an Agent tool\"\n\n    agent_type = tool_input.get(\"agent_type\", \"\")\n    expected_agent = config.get_required_agent(phase)\n\n    if not expected_agent:\n        raise ValueError(f\"No agent allowed in phase: {phase}\")\n\n    if agent_type != expected_agent:\n        raise ValueError(\n            f\"Agent '{agent_type}' is not allowed in phase: {phase}\"\n            f\"\\nExpected: {expected_agent}\"\n        )\n\n    max_allowed = config.get_agent_max_count(agent_type)\n    actual = state.count_agents(agent_type)\n    if actual >= max_allowed:\n        raise ValueError(\n            f\"Agent '{agent_type}' already at max ({max_allowed}) in phase: {phase}\"\n        )\n\n    return f\"{agent_type} agent is allowed in phase: {phase}\"\n\n\nT = TypeVar(\"T\", bound=Literal[\"in_progress\", \"completed\"])\n\n\ndef is_phase(status: T, phase: str, state: dict[str, Any]) -> T:\n    \"\"\"Validate the phase. If the phase is not allowed, raise an error.\"\"\"\n    phase_item: dict[str, Any] = next(\n        p for p in state.get(\"phase\", {}) if p[\"name\"] == phase\n    )\n    phase_status = phase_item.get(\"status\", \"\")\n    if phase_status != status:\n        return status\n    return phase_status\n\n\ndef is_skill_allowed(\n    state: dict[str, Any], hook_input: dict, config: dict[str, Any]\n) -> str:\n    \"\"\"Validate the skill. If the skill is not allowed, raise an error.\"\"\"\n\n    is_explore_in_progress = is_phase(\"in_progress\", \"explore\", state)\n    skill_name = hook_input.get(\"tool_input\", {}).get(\"skill\", \"\")\n    if skill_name == \"Research\" and is_explore_in_progress:\n        return \"Running Research in parallel with Explore\"\n\n    next_phase = validate_order(\n        is_explore_in_progress, skill_name, [\"explore\", \"research\"]\n    )\n\n    return f\"{skill_name} skill is allowed in phase: {next_phase}\"\n\n\ndef is_explore_completed(state: StateStore) -> bool:",
