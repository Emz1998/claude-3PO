ame)\n    if not agent_name:\n        return f\"No agent required for phase '{phase_name}'\"\n\n    actual = state.count_agents(agent_name)\n    if actual < 1:\n        raise ValueError(\n            f\"Phase '{phase_name}' requires agent '{agent_name}', found {actual}\"\n        )\n    max_allowed = config.get_agent_max_count(agent_name)\n    if actual > max_allowed:\n        raise ValueError(\n            f\"Phase '{phase_name}' allows max {max_allowed} '{agent_name}' agent(s), found {actual}\"\n        )\n\n    return f\"Required agent '{agent_name}' invoked for phase '{phase_name}'\"\n",
