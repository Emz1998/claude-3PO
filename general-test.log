{
    "session_id": "f6ce558c-76a8-4fba-aa17-531ea67d387f",
    "transcript_path": "/home/emhar/.claude/projects/-home-emhar-avaris-ai/f6ce558c-76a8-4fba-aa17-531ea67d387f.jsonl",
    "cwd": "/home/emhar/avaris-ai",
    "permission_mode": "bypassPermissions",
    "agent_id": "ac8c901a79d0e0efd",
