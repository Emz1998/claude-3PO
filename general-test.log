            "content": "\ndef required_agents_invoked(phase_name: str, config: Config, state: StateStore) -> str:\n    \"\"\"Check a phase (and its sub-phases) has the required agents recorded in state.\"\"\"\n    expected_agents = config.get_phase_agents(phase_name)\n    if not expected_agents:\n        return f\"No agents required for phase '{phase_name}'\"\n\n    try:\n        phase_state = state.get_phase(state.phases, phase_name)\n    except StopIteration:\n        raise ValueError(f\"Phase '{phase_name}' not found in state\")\n\n    for agent in expected_agents:\n        required = config.get_required_agent_count(phase_name, agent[\"name\"])\n        actual = state.count_agents(phase_state, agent[\"name\"])\n        if actual < required:\n            raise ValueError(\n                f\"Phase '{phase_name}' requires {required} '{agent['name']}' agent(s), found {actual}\"\n            )\n\n    for sub_cfg in config.get_sub_phases(phase_name):\n        sub_name = sub_cfg[\"name\"]\n        sub_expected = config.get_sub_phase_agents(phase_name, sub_name)\n        if not sub_expected:\n            continue\n\n        try:\n            sub_state = state.get_sub_phase(phase_state, sub_name)\n        except StopIteration:\n            raise ValueError(\n                f\"Sub-phase '{sub_name}' not found in phase '{phase_name}'\"\n            )\n\n        for agent in sub_expected:\n            required = config.get_required_sub_phase_agent_count(\n                phase_name, sub_name, agent[\"name\"]\n            )\n            actual = state.count_sub_phase_agents(sub_state, agent[\"name\"])\n            if actual < required:\n                raise ValueError(\n                    f\"Sub-phase '{sub_name}' in '{phase_name}' requires {required} \"\n                    f\"'{agent['name']}' agent(s), found {actual}\"\n                )\n\n    return f\"All required agents invoked for phase '{phase_name}'\"\n\n\n# def required_tools_invoked(config: Config, state: StateStore) -> bool:\n#     \"\"\"Check every phase (and sub-phase) has the required tools recorded in state.\"\"\"\n",
