    "session_id": "ca8d1785-2b75-4e60-9a40-bb63a927c98c",
    "transcript_path": "/home/emhar/.claude/projects/-home-emhar-avaris-ai/ca8d1785-2b75-4e60-9a40-bb63a927c98c.jsonl",
    "cwd": "/home/emhar/avaris-ai",
    "permission_mode": "default",
    "hook_event_name": "PostToolUse",
