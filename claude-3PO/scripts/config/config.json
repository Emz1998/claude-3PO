{
  "phases": [
    {
      "name": "explore",
      "workflows": ["build", "implement"],
      "read_only": true,
      "agent": "Explore",
      "agent_count": 3
    },
    {
      "name": "research",
      "workflows": ["build", "implement"],
      "read_only": true,
      "agent": "Research",
      "agent_count": 2
    },
    {
      "name": "plan",
      "workflows": ["build", "implement"],
      "docs_write": true,
      "agent": "Plan",
      "agent_count": 1
    },
    {
      "name": "plan-review",
      "workflows": ["build", "implement"],
      "read_only": true,
      "docs_edit": true,
      "agent": "PlanReview",
      "agent_count": 3,
      "checkpoint": true
    },
    {
      "name": "create-tasks",
      "workflows": ["build", "implement"],
      "auto": true
    },
    { "name": "install-deps", "workflows": ["build"], "code_write": true },
    { "name": "define-contracts", "workflows": ["build"], "code_write": true },
    {
      "name": "write-tests",
      "workflows": ["build", "implement"],
      "code_write": true,
      "auto": true
    },
    {
      "name": "test-review",
      "workflows": ["build"],
      "read_only": true,
      "code_edit": true,
      "agent": "TestReviewer",
      "agent_count": 3
    },
    {
      "name": "tests-review",
      "workflows": ["implement"],
      "read_only": true,
      "code_edit": true,
      "agent": "TestReviewer",
      "agent_count": 3
    },
    {
      "name": "write-code",
      "workflows": ["build", "implement"],
      "code_write": true,
      "auto": true
    },
    {
      "name": "quality-check",
      "workflows": ["build"],
      "read_only": true,
      "agent": "QASpecialist",
      "agent_count": 3
    },
    {
      "name": "validate",
      "workflows": ["implement"],
      "read_only": true,
      "agent": "QASpecialist",
      "agent_count": 3
    },
    {
      "name": "code-review",
      "workflows": ["build", "implement"],
      "read_only": true,
      "code_edit": true,
      "agent": "CodeReviewer",
      "agent_count": 3
    },
    { "name": "pr-create", "workflows": ["build", "implement"] },
    { "name": "ci-check", "workflows": ["build", "implement"] },
    {
      "name": "write-report",
      "workflows": ["build", "implement"],
      "docs_write": true
    },
    {
      "name": "refactor",
      "workflows": [],
      "code_write": true,
      "code_edit": true
    },
    { "name": "plan-revision", "workflows": [], "code_edit": true },
    {
      "name": "vision",
      "workflows": ["specs"],
      "docs_write": true
    },
    {
      "name": "strategy",
      "workflows": ["specs"],
      "read_only": true,
      "agent": "Research",
      "agent_count": 3
    },
    {
      "name": "decision",
      "workflows": ["specs"],
      "docs_write": true
    },
    {
      "name": "architect",
      "workflows": ["specs"],
      "read_only": true,
      "agent": "Architect",
      "agent_count": 1
    },
    {
      "name": "backlog",
      "workflows": ["specs"],
      "read_only": true,
      "agent": "ProductOwner",
      "agent_count": 1
    }
  ],

  "plan_templates": {
    "build": {
      "required_sections": [
        "## Dependencies",
        "## Tasks",
        "## Files to Modify"
      ],
      "bullet_sections": ["Dependencies", "Tasks"]
    },
    "implement": {
      "required_sections": [
        "## Context",
        "## Approach",
        "## Files to Create/Modify",
        "## Verification"
      ]
    }
  },

  "score_thresholds": {
    "plan": { "confidence_score": 80, "quality": 80 },
    "tests": { "confidence_score": 80, "quality": 80 },
    "code": { "confidence_score": 90, "quality": 80 }
  },

  "safe_domains": [
    "docs.python.org",
    "docs.anthropic.com",
    "developer.mozilla.org",
    "reactjs.org",
    "react.dev",
    "nextjs.org",
    "tailwindcss.com",
    "github.com",
    "stackoverflow.com",
    "pypi.org",
    "npmjs.com",
    "typescriptlang.org",
    "nodejs.org",
    "firebase.google.com",
    "supabase.com",
    "expo.dev",
    "reactnative.dev",
    "code.claude.com",
    "vercel.com",
    "medium.com",
    "web.dev",
    "developers.google.com",
    "css-tricks.com"
  ],

  "paths": {
    "state_jsonl": ".claude/state.jsonl",
    "log_file": "build.log",
    "debug_log_file": "debug.log",
    "plan_file": ".claude/plans/latest-plan.md",
    "plan_archive_dir": ".claude/plans/archive",
    "test_file": ".claude/tests/test.md",
    "code_file": ".claude/code/code.md",
    "report_file": ".claude/reports/report.md",
    "contracts_file": ".claude/contracts/latest-contracts.md",
    "contracts_archive_dir": ".claude/contracts/archive",
    "product_vision_file": "projects/docs/product-vision.md",
    "decisions_file": "projects/docs/decisions.md",
    "architecture_file": "projects/docs/architecture.md",
    "backlog_md_file": "projects/docs/backlog.md",
    "backlog_json_file": "projects/docs/backlog.json"
  }
}
