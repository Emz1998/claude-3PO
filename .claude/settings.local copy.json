{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run .claude/scripts/hooks_toggler/activate_hooks.py)",
      "Bash(uv run .claude/scripts/hooks_toggler/deactivate_hooks.py)",
      "Skill(skills-creator)",
      "Skill(skills-creator:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(dd:*)",
      "Bash(format:*)",
      "Bash(chmod -R 000 /)",
      "Bash(chown -R root /)",
      "Bash(sudo rm -rf /)",
      "Bash(sudo dd:*)",
      "Bash(sudo mkfs:*)",
      "Bash(sudo fdisk:*)",
      "Bash(sudo format:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(init 0)",
      "Bash(init 6)",
      "Bash(systemctl poweroff)",
      "Bash(systemctl reboot)",
      "Bash(systemctl halt)",
      "Bash(sudo shutdown:*)",
      "Bash(sudo reboot:*)",
      "Bash(sudo halt:*)",
      "Bash(sudo init 0)",
      "Bash(sudo init 6)",
      "Bash(sudo systemctl poweroff)",
      "Bash(sudo systemctl reboot)",
      "Bash(sudo systemctl halt)"
    ],
    "ask": [
      "ExitPlanMode"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "sequentialthinking",
    "mcp-server-firecrawl",
    "playwright",
    "context7",
    "shadcn",
    "zen"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/security/security.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/tests/general_test.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/pre_tool_use.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/post_tool_use.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/stop.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /$CLAUDE_PROJECT_DIR/.claude/statusline-git-format.sh"
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false
  }
}
