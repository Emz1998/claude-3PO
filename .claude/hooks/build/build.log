-------------------------------------------------------------\nPLAN_REVIEW_THRESHOLD = {\"confidence\": 80, \"quality\": 80}\n\n# ---------------------------------------------------------------------------\n# File type patterns\n# ---------------------------------------------------------------------------\nCODE_EXTENSIONS = {\n    \".py\",\n    \".ts\",\n    \".tsx\",\n    \".js\",\n    \".jsx\",\n    \".go\",\n    \".rs\",\n    \".java\",\n    \".kt\",\n    \".swift\",\n    \".c\",\n    \".cpp\",\n    \".h\",\n    \".rb\",\n    \".sh\",\n}\n\nTEST_PATH_PATTERNS = [\n    re.compile(r\"(^|/)(tests?|__tests__|spec)(/|$)\"),\n    re.compile(r\"(^|/)(test_.*|.*_test)\\.(py|js|ts|jsx|tsx)$\"),\n    re.compile(r\"(^|/).*\\.(test|spec)\\.(js|jsx|ts|tsx)$\"),\n]\n\nCODEBASE_MD = \"CODEBASE.md\"\n\n# ---------------------------------------------------------------------------\n# Bash command patterns\n# ---------------------------------------------------------------------------\nPR_COMMAND_PATTERNS = [r\"\\bgh\\s+pr\\s+create\\b\", r\"\\bgit\\s+push\\b\"]\nTEST_RUN_PATTERNS = [\n    r\"\\bpytest\\b\",\n    r\"\\bnpm\\s+test\\b\",\n    r\"\\byarn\\s+test\\b\",\n    r\"\\bgo\\s+test\\b\",\n    r\"\\bjest\\b\",\n    r\"\\bvitest\\b\",\n]\nCI_CHECK_PATTERNS = [r\"\\bgh\\s+pr\\s+checks\\b\", r\"\\bgh\\s+run\\s+view\\b\"]\n\n# ---------------------------------------------------------------------------\n# Skill / story ID patterns\n# ---------------------------------------------------------------------------\nSTORY_ID_PATTERN = re.compile(r\"\\b([A-Z]{2,}-\\d+)\\b\")\n\n# ---------------------------------------------------------------------------\n# Plan template validation\n# ---------------------------------------------------------------------------\nREQUIRED_SECTIONS = [\n    r\"^##\\s+Context\",\n    r\"^##\\s+(Approach|Steps)\",\n    r\"^##\\s+(Files to Modify|Critical Files)\",\n    r\"^##\\s+Verification\",\n]\n\n# ---------------------------------------------------------------------------\n# Domain whitelist\n# ---------------------------------------------------------------------------\nSAFE_DOMAINS = [\n    \"docs.python.org\",\n    \"docs.anthropic.com\",\n    \"developer.mozilla.org\",\n    \"reactjs.org\",\n    \"react.dev\",\n    \"nextjs.org\",\n    \"tailwindcss.com\",\n    \"github.com\",\n    \"stackoverflow.com\",\n    \"pypi.org\",\n    \"npmjs.com\",\n    \"typescriptlang.org\",\n    \"nodejs.org\",\n    \"firebase.google.com\",\n    \"supabase.com\",\n    \"expo.dev\",\n    \"reactnative.dev\",\n    \"code.claude.com\",\n    \"vercel.com\",\n    \"medium.com\",\n    \"web.dev\",\n    \"developers.google.com\",\n    \"css-tricks.com\",\n]\n", "structuredPatch": [{"oldStart": 25, "oldLines": 6, "newStart": 25, "newLines": 7, "lines": [" # Review thresholds", " # ---------------------------------------------------------------------------", " PLAN_REVIEW_THRESHOLD = {\"confidence\": 80, \"quality\": 80}", "+CODE_REVIEW_THRESHOLD = {\"confidence\": 80, \"quality\": 80}", " ", " # ---------------------------------------------------------------------------", " # File type patterns"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01G4CS2YHj3i6anmSD14PPbS"}}
