st\n# ---------------------------------------------------------------------------\nSAFE_DOMAINS = [\n    \"docs.python.org\",\n    \"docs.anthropic.com\",\n    \"developer.mozilla.org\",\n    \"reactjs.org\",\n    \"react.dev\",\n    \"nextjs.org\",\n    \"tailwindcss.com\",\n    \"github.com\",\n    \"stackoverflow.com\",\n    \"pypi.org\",\n    \"npmjs.com\",\n    \"typescriptlang.org\",\n    \"nodejs.org\",\n    \"firebase.google.com\",\n    \"supabase.com\",\n    \"expo.dev\",\n    \"reactnative.dev\",\n    \"code.claude.com\",\n    \"vercel.com\",\n    \"medium.com\",\n    \"web.dev\",\n    \"developers.google.com\",\n    \"css-tricks.com\",\n]\n", "structuredPatch": [{"oldStart": 7, "oldLines": 7, "newStart": 7, "newLines": 7, "lines": [" # ---------------------------------------------------------------------------", " AGENT_ONLY_PHASES = {\"explore\", \"plan\"}", " AGENT_PLUS_WRITE_PHASES = {\"review\"}", "-CODING_PHASES = {\"write-tests\", \"write-code\", \"validate\", \"ci-check\", \"report\"}", "+CODING_PHASES = {\"write-tests\", \"write-code\", \"validate\", \"code-review\", \"report\"}", " PLAN_ALLOWED_STOP_PHASES = {\"present-plan\", \"completed\", \"failed\"}", " ", " # ---------------------------------------------------------------------------"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01Wf18M2W7oYF8i5usArgBic"}}
