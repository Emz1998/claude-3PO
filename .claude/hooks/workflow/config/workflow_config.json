{
  "phases": {
    "base": [
      "explore",
      "plan",
      "plan-consult",
      "finalize-plan",
      "code",
      "commit"
    ],
    "simple": [
      "explore",
      "plan",
      "execute",
      "commit"
    ],
    "tdd": [
      "write-test",
      "review-test",
      "write-code",
      "code-review",
      "refactor",
      "validate"
    ],
    "test-after": [
      "write-code",
      "write-test",
      "review-test",
      "code-review",
      "refactor",
      "validate"
    ]
  },
  "subagents": {
    "explore": "codebase-explorer",
    "plan": "planner",
    "plan-consult": "plan-consultant",
    "finalize-plan": "planner",
    "commit": "version-manager",
    "write-test": "test-engineer",
    "review-test": "test-reviewer",
    "write-code": "main-agent",
    "code-review": "code-reviewer",
    "refactor": "main-agent",
    "validate": "validator"
  },
  "deliverables": {
    "explore": [
      {
        "type": "files",
        "action": "read",
        "pattern": "/home/emhar/avaris-ai/prompt.md",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*codebase-status/codebase-status_.*\\.md$",
        "priority": 2
      }
    ],
    "plan": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*codebase-status/codebase-status_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*plans/initial-plan_.*\\.md$",
        "priority": 2
      }
    ],
    "plan-consult": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*plans/initial-plan_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*plans/plan-consultation_.*\\.md$",
        "priority": 2
      }
    ],
    "finalize-plan": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*plans/plan-consultation_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*plans/final-plan_.*\\.md$",
        "priority": 2
      }
    ],
    "code": [],
    "write-test": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*plans/final-plan_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*tests/test-summary_.*\\.md$",
        "priority": 2
      }
    ],
    "review-test": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*tests/test-summary_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*tests/test-quality-report_.*\\.md$",
        "priority": 2
      }
    ],
    "write-code": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*plans/final-plan_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*misc/code-test_.*\\.md$",
        "priority": 2
      }
    ],
    "code-review": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*misc/code-test_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*reviews/code-review_.*\\.md$",
        "priority": 2
      }
    ],
    "refactor": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*reviews/code-review_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*reports/refactor_.*\\.md$",
        "priority": 2
      }
    ],
    "validate": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*reports/refactor_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*reports/validation_report_.*\\.md$",
        "priority": 2
      }
    ],
    "commit": [
      {
        "type": "files",
        "action": "read",
        "pattern": ".*reports/validation_report_.*\\.md$",
        "priority": 1
      },
      {
        "type": "files",
        "action": "write",
        "pattern": ".*reports/commit_.*\\.md$",
        "priority": 2
      }
    ]
  },
  "required_read_order": [
    "recap.md",
    "ms-summary.md",
    "tasks.md",
    "codebase-status.md",
    "plan.md",
    "plan-consultation.md"
  ]
}
