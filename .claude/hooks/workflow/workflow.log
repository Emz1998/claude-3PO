/workflow/dispatchers/user_prompt_submit.py", ".claude/hooks/workflow/tests/test_write_guard.py", ".claude/hooks/workflow/dry_runs/plan_dry_run.py", ".claude/hooks/workflow/logger.py", ".claude/hooks/workflow/utils/logger.py", ".claude/hooks/workflow/guards/read_guard.py", ".claude/hooks/workflow/guards/webfetch_guard.py", ".claude/hooks/workflow/hook.py", ".claude/hooks/workflow/dispatchers/session_start.py", ".claude/hooks/workflow/tests/test_stop_guard.py", ".claude/hooks/workflow/tests/test_read_guard.py", ".claude/hooks/workflow/tests/test_session_start.py", ".claude/hooks/workflow/dispatchers/task_completed.py", ".claude/hooks/workflow/guards/skill_guard.py", ".claude/hooks/workflow/guards/agent_guard.py", ".claude/hooks/workflow/guards/task_guard.py", ".claude/hooks/workflow/reminder.py", ".claude/hooks/workflow/tests/test_agent_guard.py", ".claude/hooks/workflow/tests/test_recorder.py", ".claude/hooks/workflow/tests/test_reminder.py", ".claude/hooks/workflow/tests/test_task_guard.py", ".claude/hooks/workflow/guards/subagent_stop_guard.py", ".claude/hooks/workflow/guardrail.py", ".claude/hooks/workflow/dispatchers/subagent_stop.py", ".claude/hooks/workflow/tests/test_guardrail.py", ".claude/hooks/workflow/config/constants.py", ".claude/hooks/workflow/dry_runs/implement_dry_run.py", ".claude/hooks/workflow/tests/test_bash_guard.py", ".claude/hooks/workflow/dispatchers/post_tool_use.py", ".claude/hooks/workflow/guards/stop_guard.py", ".claude/hooks/workflow/tests/test_commit_format.py", ".claude/hooks/workflow/guards/bash_guard.py", ".claude/hooks/workflow/config/paths.py", ".claude/hooks/workflow/config/__init__.py", ".claude/hooks/workflow/auto_commit.py", ".claude/hooks/workflow/tests/test_auto_commit.py", ".claude/hooks/workflow/recorder.py", ".claude/hooks/workflow/guards/write_guard.py"], "durationMs": 50, "numFiles": 68, "truncated": false}, "tool_use_id": "toolu_01M8AtDqsJFZjUiX4bcpfsUg"}}
