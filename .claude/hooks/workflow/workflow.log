     \"description\": \"x\",\n            \"prompt\": \"x\",\n            \"run_in_background\": run_in_background,\n        },\n        \"tool_use_id\": tool_use_id,\n        \"session_id\": \"s\", \"transcript_path\": \"t\", \"cwd\": \".\", \"permission_mode\": \"default\",\n    }", "stderr": "", "interrupted": false, "isImage": false, "noOutputExpected": false}, "tool_use_id": "toolu_015EMsVsYRr6eroJLHvJenn5"}}
