{"ts": "2026-04-03T23:15:44.012", "event": "PostToolUse:raw_input", "raw_input": {"session_id": "993193fe-53b9-488d-8678-f9e2417029d6", "transcript_path": "/home/emhar/.claude/projects/-home-emhar-avaris-ai/993193fe-53b9-488d-8678-f9e2417029d6.jsonl", "cwd": "/home/emhar/avaris-ai", "permission_mode": "bypassPermissions", "hook_event_name": "PostToolUse", "tool_name": "Bash", "tool_input": {"command": "tail -20 .claude/hooks/workflow/workflow.log 2>&1", "description": "Check workflow log", "dangerouslyDisableSandbox": true}, "tool_response": {"stdout": "{\"ts\": \"2026-04-03T23:14:18.742\", \"event\": \"PostToolUse:raw_input\", \"raw_input\": {\"session_id\": \"993193fe-53b9-488d-8678-f9e2417029d6\", \"transcript_path\": \"/home/emhar/.claude/projects/-home-emhar-avaris-ai/993193fe-53b9-488d-8678-f9e2417029d6.jsonl\", \"cwd\": \"/home/emhar/avaris-ai\", \"permission_mode\": \"bypassPermissions\", \"hook_event_name\": \"PostToolUse\", \"tool_name\": \"Bash\", \"tool_input\": {\"command\": \"gh pr checks 294\", \"description\": \"gh pr checks 294\", \"dangerouslyDisableSandbox\": true}, \"tool_response\": {\"stdout\": \"GitGuardian Security Checks\\tpass\\t1s\\thttps://dashboard.gitguardian.com\\t\\nclaude-review\\tpass\\t8m47s\\thttps://github.com/Emz1998/avaris-ai/actions/runs/23969049444/job/69914698397\", \"stderr\": \"\", \"interrupted\": false, \"isImage\": false, \"noOutputExpected\": false, \"dangerouslyDisableSandbox\": true}, \"tool_use_id\": \"toolu_01SZjTpswwKfhBe3e7vDqdsw\"}}\n{\"ts\": \"2026-04-03T23:14:18.901\", \"event\": \"record_bash:pending\", \"output\": \"\"}", "stderr": "", "interrupted": false, "isImage": false, "noOutputExpected": false, "dangerouslyDisableSandbox": true}, "tool_use_id": "toolu_01TJJcGdaPXMwjYkNgoVPj33"}}
