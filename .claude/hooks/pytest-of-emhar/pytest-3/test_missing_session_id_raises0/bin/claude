#!/usr/bin/env python3
import json, sys
responses = ["irrelevant"]
counter = r'/home/emhar/avaris-ai/.claude/hooks/pytest-of-emhar/pytest-3/test_missing_session_id_raises0/bin/_call_count'
n = int(open(counter).read())
open(counter, 'w').write(str(n + 1))
text = responses[min(n, len(responses) - 1)]
print(json.dumps({"session_id": f"claude-sid-{n}", "result": text}))
