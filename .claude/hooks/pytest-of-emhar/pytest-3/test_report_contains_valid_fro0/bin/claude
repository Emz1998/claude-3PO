#!/usr/bin/env python3
import json, sys
responses = ["---\nconfidence_score: 85\nquality_score: 80\nfiles_to_revise:\n  - /home/emhar/avaris-ai/.claude/hooks/pytest-of-emhar/pytest-3/test_report_contains_valid_fro0/service.ts\n---\n\nLooks good."]
counter = r'/home/emhar/avaris-ai/.claude/hooks/pytest-of-emhar/pytest-3/test_report_contains_valid_fro0/bin/_call_count'
n = int(open(counter).read())
open(counter, 'w').write(str(n + 1))
text = responses[min(n, len(responses) - 1)]
print(json.dumps({"session_id": f"claude-sid-{n}", "result": text}))
