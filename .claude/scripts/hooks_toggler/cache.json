{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "code-reviewer|test-reviewer|plan-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/validation/validation_loop.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f \"$CLAUDE_PROJECT_DIR/.bash_profile\" \"$CLAUDE_PROJECT_DIR/.bashrc\" \"$CLAUDE_PROJECT_DIR/.profile\" \"$CLAUDE_PROJECT_DIR/.zprofile\" \"$CLAUDE_PROJECT_DIR/.zshrc\" \"$CLAUDE_PROJECT_DIR/.ripgreprc\" \"$CLAUDE_PROJECT_DIR/HEAD\" \"$CLAUDE_PROJECT_DIR/config\" && rm -rf \"$CLAUDE_PROJECT_DIR/hooks\" \"$CLAUDE_PROJECT_DIR/objects\" \"$CLAUDE_PROJECT_DIR/refs\" \"$CLAUDE_PROJECT_DIR/.idea\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/guards/stop_guard.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/security/security.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/validation/decision_handler.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/guards/code_phase.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/handlers/build_entry.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/handlers/implement_trigger.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skills/hooks_toggler.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/handlers/recorder.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow/handlers/reminders.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "last_action": "activate"
}