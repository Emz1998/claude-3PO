{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatchers/stop.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/security/security.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatchers/pre_tool.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PermissionRequest": [],
    "SubagentStop": [],
    "SessionEnd": [],
    "PreCompact": [],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatchers/user_prompt.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [],
    "SessionStart": [],
    "PostToolUse": [
      {
        "matcher": "Skill|Write|Edit|Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/dispatchers/post_tool.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}